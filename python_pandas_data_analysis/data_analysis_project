    "#TODO: Create Interactive Plot in plotly.express\n",
    "import plotly.express as px\n",
    "plot_data = df[['pl_rade', 'pl_bmasse', 'pl_orbper', 'discoverymethod']].dropna()\n",
    "plot_data = plot_data[\n",
    "    (plot_data['pl_rade'] > 0) &\n",
    "    (plot_data['pl_bmasse'] > 0) &\n",
    "    (plot_data['pl_orbper'] > 0)\n",
    "]\n",
    "fig = px.scatter_3d(\n",
    "    plot_data,\n",
    "    x='pl_rade',\n",
    "    y='pl_bmasse',\n",
    "    z='pl_orbper',\n",
    "    color='discoverymethod',\n",
    "    title='3D Visualization of Planet Characteristics',\n",
    "    labels={\n",
    "        'pl_rade': 'Planet Radius',\n",
    "        'pl_bmasse': 'Planet Mass',\n",
    "        'pl_orbper': 'Orbital Period',\n",
    "        'discoverymethod': 'Discovery Method'\n",
    "    }\n",
    ")\n",
    "\n",
    "fig.update_traces(marker=dict(size=4))\n",
    "fig.update_layout(\n",
    "    scene=dict(\n",
    "        xaxis=dict(type='log', title='Planet Radius'),\n",
    "        yaxis=dict(type='log', title='Planet Mass'),\n",
    "        zaxis=dict(type='log', title='Orbital Period')\n",
    "    )\n",
    ")\n",
    "\n",
    "fig\n"
   ]
