    "#TODO:  Create Interactive Line Plots\n",
    "radius_stats_by_year = (\n",
    "    df.groupby('disc_year')['pl_rade']\n",
    "      .agg(\n",
    "          mean='mean',\n",
    "          median='median',\n",
    "          mode=lambda x: x.mode().iloc[0] if not x.mode().empty else None\n",
    "      )\n",
    "      .sort_index()\n",
    ")\n",
    "mean_line = radius_stats_by_year.hvplot.line(\n",
    "    y='mean',\n",
    "    color='blue',\n",
    "    label='Mean',\n",
    "    title='Planet Radius Statistics Over Discovery Years',\n",
    "    xlabel='Discovery Year',\n",
    "    ylabel='Planet Radius'\n",
    ")\n",
    "\n",
    "median_line = radius_stats_by_year.hvplot.line(\n",
    "    y='median',\n",
    "    color='green',\n",
    "    label='Median'\n",
    ")\n",
    "\n",
    "mode_line = radius_stats_by_year.hvplot.line(\n",
    "    y='mode',\n",
    "    color='red',\n",
    "    label='Mode'\n",
    ")\n",
    "\n",
    "mean_line * median_line * mode_line\n"
   ]
